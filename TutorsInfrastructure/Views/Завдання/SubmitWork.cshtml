@model TutorsDomain.Model.Завдання
@{
    ViewData["Title"] = "Здати роботу";
}
<h1>Здати роботу</h1>
<h4>@Model.ОписЗавдання</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="ЗдатиРоботу" enctype="multipart/form-data">
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="form-group mb-3">
                <label class="control-label">Файл з роботою</label>
                <input type="file" name="файл" class="form-control"
                       accept=".pdf,.doc,.docx,.txt,.jpg,.png,.zip" />
                <small class="text-muted">Завантажте виконану роботу</small>
            </div>
            <div class="form-group">
                <input type="submit" value="Здати" class="btn btn-success" />
                <a asp-action="Details" asp-route-id="@Model.Id"
                   class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>