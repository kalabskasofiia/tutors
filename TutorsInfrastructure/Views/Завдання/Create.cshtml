@model TutorsDomain.Model.Завдання
@{
    ViewData["Title"] = "Створити завдання";
}
<h1>Створити завдання</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" name="LessonId" value="@ViewBag.LessonId" />

            <div class="form-group mb-3">
                <label asp-for="ОписЗавдання" class="control-label">Опис завдання</label>
                <textarea asp-for="ОписЗавдання" class="form-control" rows="3"></textarea>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ТипЗавдання" class="control-label">Тип завдання</label>
                <select asp-for="ТипЗавдання" class="form-control">
                    <option value="">-- Оберіть тип --</option>
                    <option value="Домашнє завдання">Домашнє завдання</option>
                    <option value="Контрольна робота">Контрольна робота</option>
                    <option value="Тест">Тест</option>
                    <option value="Проєкт">Проєкт</option>
                </select>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Дедлайн" class="control-label">Дедлайн</label>
                <input asp-for="Дедлайн" type="date" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label class="control-label">Файл завдання</label>
                <input type="file" name="файл" class="form-control"
                       accept=".pdf,.doc,.docx,.txt,.jpg,.png,.zip" />
                <small class="text-muted">Дозволені формати: PDF, Word, TXT, зображення, ZIP</small>
            </div>
            <div class="form-group">
                <input type="submit" value="Створити" class="btn btn-primary" />
                <a asp-controller="Урок" asp-action="Details"
                   asp-route-id="@ViewBag.LessonId" class="btn btn-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>