            </div>
            <div class="form-group">
                <label asp-for="МаксимальнийБал" class="control-label"></label>
                <input asp-for="МаксимальнийБал" class="form-control" />
                <span asp-validation-for="МаксимальнийБал" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Id" />
